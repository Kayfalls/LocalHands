# App
PROJECT_NAME=Local Hands 2.0 API
APP_VERSION=2.0.0
ENVIRONMENT=development

# Backend runtime
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/local_hands
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Default accounts (seeded at startup)
DEFAULT_EMPLOYER_EMAIL=employer@localhands.com
DEFAULT_EMPLOYER_PASSWORD=ChangeMe123!
DEFAULT_WORKER_EMAIL=worker@localhands.com
DEFAULT_WORKER_PASSWORD=ChangeMe123!

# Huawei Cloud
HUAWEI_PROJECT_ID=
HUAWEI_REGION=af-south-1
HUAWEI_IAM_ENDPOINT=https://iam.myhuaweicloud.com/v3/auth/tokens
HUAWEI_IAM_DOMAIN_NAME=
HUAWEI_IAM_USERNAME=
HUAWEI_IAM_PASSWORD=

# Huawei OBS
HUAWEI_OBS_ENDPOINT=https://obs.af-south-1.myhuaweicloud.com
HUAWEI_OBS_ACCESS_KEY=
HUAWEI_OBS_SECRET_KEY=
HUAWEI_OBS_BUCKET=local-hands-assets

# ModelArts
MODELARTS_SKILL_ENDPOINT=

# Frontend base URLs
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
